# ─────────────────────────────────────────────────────────────────────────────
# Security Operations Dashboard – Environment Variables
# Copy this file to .env and fill in your real credentials.
#
#   cp .env.example .env
#   nano .env
#   docker compose up -d --build
#
# IMPORTANT: Never commit .env to source control. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Dashboard port ────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Fortinet FortiGate ────────────────────────────────────────────────────────
# REST API token: FortiGate → System → Administrators → API Users → Create new
REACT_APP_FORTINET_HOST=https://192.168.1.1
REACT_APP_FORTINET_APIKEY=your-fortigate-rest-api-token

# ── Palo Alto (Panorama / standalone firewall) ────────────────────────────────
# Generate key: https://<panorama>/api/?type=keygen&user=<u>&password=<p>
REACT_APP_PALOALTO_HOST=https://panorama.company.com
REACT_APP_PALOALTO_APIKEY=your-pan-os-api-key

# ── UpGuard Cyber Risk ────────────────────────────────────────────────────────
# Found at: Settings → API Keys in your UpGuard portal
REACT_APP_UPGUARD_APIKEY=your-upguard-api-key

# ── Azure Defender for Cloud ──────────────────────────────────────────────────
# Register an App in Azure AD with "Security Reader" role on the subscription.
# Azure Portal → App Registrations → New → Certificates & Secrets → Client secret
REACT_APP_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REACT_APP_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REACT_APP_AZURE_CLIENT_SECRET=your-azure-client-secret
REACT_APP_AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Qualys VMDR / VAPT ────────────────────────────────────────────────────────
# Use a dedicated Qualys reader account. API access must be enabled in the
# Qualys subscription (Subscription → Users → Edit → Enable API).
# NOTE: Qualys blocks direct browser requests (CORS). Run with --profile qualys
# to start the qualys-proxy sidecar, or point these at your own backend proxy.
REACT_APP_QUALYS_USERNAME=your-qualys-username
REACT_APP_QUALYS_PASSWORD=your-qualys-password

# ── ManageEngine Endpoint Central / Patch Manager / Encryption ───────────────
# Generate OAuth token: ME portal → Admin → API Explorer → Generate Token
# Scope needed: READ access to Computers, Patches, Encryption
REACT_APP_ME_HOST=https://meserver.company.com:8443
REACT_APP_ME_APIKEY=your-zoho-oauth-token

# ─────────────────────────────────────────────────────────────────────────────
# Service Ports (Docker internal — change only if ports conflict on your host)
# ─────────────────────────────────────────────────────────────────────────────
BACKEND_PORT=4000        # SecOps data collection + integrations API
GRC_PORT=4001            # GRC Compliance Service (DPDPA / PCI DSS / ISO 27001)
VULN_PORT=4002           # Vulnerability Assessment Service

# ─────────────────────────────────────────────────────────────────────────────
# Claude AI — Vulnerability Assessment (AI analysis of scan results)
# Get your key at: https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Kali Linux — SSH access for remote scan execution
# Configure in Settings → Kali Linux integration
# ─────────────────────────────────────────────────────────────────────────────
# KALI_HOST=192.168.1.100
# KALI_PORT=22
# KALI_USER=kali
# KALI_PASS=yourpassword   (or use SSH key)

# ─────────────────────────────────────────────────────────────────────────────
# Nessus — REST API (runs on https://localhost:8834 by default)
# Configure in Settings → Nessus integration
# ─────────────────────────────────────────────────────────────────────────────
# NESSUS_HOST=localhost
# NESSUS_PORT=8834
# NESSUS_USER=admin
# NESSUS_PASS=yourpassword

# ─────────────────────────────────────────────────────────────────────────────
# OWASP ZAProxy — REST API (runs on http://localhost:8080 by default)
# Configure in Settings → ZAProxy integration
# ─────────────────────────────────────────────────────────────────────────────
# ZAP_HOST=localhost
# ZAP_PORT=8080
# ZAP_API_KEY=your-zap-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Kali Linux — External SSH server for vulnerability scanning
# The vuln service connects to your Kali machine via SSH and runs tools
# (nmap, nikto, gobuster, sslscan, sqlmap, whatweb, masscan, dnsenum).
# These can also be configured via Settings → Kali Linux in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────
KALI_HOST=192.168.101.6
KALI_PORT=22
KALI_USER=kali
KALI_PASS=kali

# ─────────────────────────────────────────────────────────────────────────────
# OWASP ZAProxy Docker — auto-deployed via docker-compose
# The zaproxy container runs ghcr.io/zaproxy/zaproxy:stable in daemon mode.
# Port 8080 = REST API, port 8090 = ZAP Web UI (optional).
# API key is passed to the container via command args; set a strong value here.
# ─────────────────────────────────────────────────────────────────────────────
ZAP_API_KEY=secops-zap-key
